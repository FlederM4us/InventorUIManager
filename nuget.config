<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="GitHub_FlederM4us" value="https://nuget.pkg.github.com/FlederM4us/index.json" />
  </packageSources>
  
  <packageSourceCredentials>
    <GitHub_FlederM4us>
      <add key="Username" value="FlederM4us" />
      <add key="ClearTextPassword" value="%GH_NUGET_AUTH_TOKEN%" />
    </GitHub_FlederM4us>
  </packageSourceCredentials>

  <disabledPackageSources>
    <add key="GitHub_FlederM4us" value="true" />
  </disabledPackageSources>
</configuration>